rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // User profile: private to the owner. Clients may create/update only their
    // own profile, and only the safe fields (server fields are Function-only).
    match /users/{uid} {
      allow read: if isOwner(uid);
      // Client may only ever set/modify these safe fields. Server-only fields
      // (premium, giveToGetCount, unlockedWalls) are written by Functions via
      // the Admin SDK, which bypasses these rules.
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['phoneHash','displayName','consentAt','ageConfirmed']);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['phoneHash','displayName','consentAt','ageConfirmed','fcmToken']);
      allow delete: if false; // erasure happens via Cloud Function only

      // Inbox (received feedback) is readable by the owner; written by Functions.
      match /inbox/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Walls: aggregates only, never client-writable. NOT world-readable —
    // the doc id is an (unsalted, low-entropy) phone hash, so a public read
    // rule would let anyone enumerate every member's number offline. Only the
    // wall's own owner may read it directly; viewing another user's public wall
    // goes through the getPublicWall Function, which enforces the give-to-get
    // gate + block checks server-side.
    match /walls/{phoneHash} {
      allow read: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.phoneHash == phoneHash;
      allow write: if false; // Functions only (admin SDK bypasses rules)
    }

    // Raw reviews are NEVER client-readable (reviewer anonymity) or writable.
    match /reviews/{id} {
      allow read, write: if false;
    }

    // Dedup keys, escrow invites, disputes, reports, blocks: Functions only.
    match /reviewDedup/{id}     { allow read, write: if false; }
    match /invites/{id}         { allow read, write: if false; }
    match /disputes/{id}        { allow read, write: if false; }
    match /reports/{id}         { allow read, write: if false; }
    match /blocks/{id}          { allow read, write: if false; }

    // Gamification: readable only when the user opted into leaderboards, or
    // when it's your own doc. Prevents harvesting display names + scores of
    // users who never consented to appear publicly. Function-only write.
    match /gamification/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid || resource.data.leaderboardOptIn == true);
      allow write: if false;
    }

    // Feedback campaigns: owner manages their own requests.
    match /feedbackRequests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Payment ledger: Functions only.
    match /ledger/{id} { allow read, write: if false; }
  }
}
